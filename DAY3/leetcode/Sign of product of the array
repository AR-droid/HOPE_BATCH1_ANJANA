class Solution {
    public int arraySign(int[] nums) {
        int product=1;
        for(int i:nums){
            if (i==0){
                product=0;
            }
            if (i<1){
                i=-1;
            }
            if(i>1){
                i=1;
            }

            product=product*i;

        }
         return product;
    }
}
